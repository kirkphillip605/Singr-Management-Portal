# =============================================================================
# Database
# =============================================================================
# PostgreSQL connection string. The app and Prisma both read this.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/[DB]"

# =============================================================================
# Better Auth (required)
# =============================================================================
# Secret used to sign sessions. Generate with: openssl rand -base64 32
# Required — the app refuses to start without it.
BETTER_AUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# Public base URL of the app, used for OAuth redirects, password-reset links,
# and email verification links.
BETTER_AUTH_URL="https://example.com"
# Optional client-side override of the Better Auth base URL used by the
# browser SDK in src/lib/auth-client.ts. Leave unset to use the current
# window origin (the recommended setup).
NEXT_PUBLIC_BETTER_AUTH_URL=""

# Legacy NextAuth env vars — still read as fallbacks during the migration to
# Better Auth. Set BETTER_AUTH_SECRET / BETTER_AUTH_URL above for new
# installs; these only need values if you are upgrading from an older deploy
# that already had them set. NEXTAUTH_URL is also currently used to build
# Stripe billing return/success URLs and the venue/api-keys public URL hints.
NEXTAUTH_SECRET=""
NEXTAUTH_URL=""

# =============================================================================
# Google OAuth (optional — leave empty to disable Google sign-in)
# =============================================================================
# When set, "Continue with Google" appears on sign-in/sign-up. The public
# client id is also exposed to the browser to gate the button.
# Obtain from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# Legacy fallback only — historically some setups stored the Google OAuth
# client id/secret under the NEXT_PUBLIC_* names. New installs should leave
# these empty and use the server-side variables above.
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=""

# =============================================================================
# Twilio (optional — required for phone OTP sign-in and SMS-based 2FA)
# =============================================================================
# Without these, phone OTPs are logged to the server console instead of sent.
# Obtain from https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# =============================================================================
# SMTP email transport (optional — required for password reset, email
# verification, and email-based 2FA codes to be delivered)
# =============================================================================
# Works with any SMTP provider (SendGrid, Postmark, SES, Mailgun, Resend
# SMTP bridge, plain SMTP). When unset, auth emails are logged instead.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# "From" address on outbound auth emails. EMAIL_FROM is a legacy fallback.
SMTP_FROM="no-reply@example.com"
EMAIL_FROM=""

# =============================================================================
# Stripe (required for billing & subscriptions)
# =============================================================================
# Obtain from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret from the Stripe dashboard webhooks page. Required for
# /api/webhooks/stripe to verify event signatures.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Pinned Stripe API version used by the server SDK.
STRIPE_API_VERSION="2024-06-20"

# =============================================================================
# HERE Maps (required for venue search and geocoding)
# =============================================================================
# Obtain from https://platform.here.com
HERE_API_KEY=""

# =============================================================================
# Sentry (optional — error monitoring)
# =============================================================================
# Public DSN reported from the browser; auth token is used at build time to
# upload sourcemaps.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# =============================================================================
# App configuration
# =============================================================================
NODE_ENV="development"
# Public URL override used in a few links/metadata (defaults to BETTER_AUTH_URL).
NEXT_PUBLIC_APP_URL="http://localhost:5000"
# Auto-set by Replit when running in a Replit workspace — the public hostname
# of the dev container. The auth layer reads this to derive the trusted
# origin / OAuth callback base URL when BETTER_AUTH_URL is not set. Do not
# set this manually outside Replit.
REPLIT_DEV_DOMAIN=""
# Winston logger level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL="debug"

# Prisma client log level (query | info | warn | error).
PRISMA_LOG_LEVEL="query"

# =============================================================================
# OpenKJ API rate limiting
# =============================================================================
# Max requests per window, and window length in milliseconds (default: 1000/hr).
API_RATE_LIMIT_MAX="1000"
API_RATE_LIMIT_WINDOW="3600000"

# =============================================================================
# Support contact information (shown in the support UI)
# =============================================================================
SUPPORT_PHONE="+1 (605) 956-0173"
SUPPORT_EMAIL="support@singrkaraoke.com"
SUPPORT_DOCS="https://docs.singrkaraoke.com"
